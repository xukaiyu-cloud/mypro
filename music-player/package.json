{
  "name": "music-player",
  "version": "1.0.0",
  "description": "桌面端音乐播放器与在线歌单服务",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.musicplayer.app",
    "productName": "音乐播放器",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "server/**/*",
      "!server/node_modules",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": ["dmg"],
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "resources/icon.png"
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "element-plus": "^2.9.0",
    "pinia": "^2.2.0",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.1.0",
    "sass": "^1.80.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0"
  }
}